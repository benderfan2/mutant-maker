[ext_resource type="Script" uid="uid://bvg3dreo5cyh" path="res://Scripts/trait.gd" id="1_opwdk"]

[resource]
script = ExtResource("1_opwdk")
name = "Myriadlimbed"
type = 2
cost = 15
description = "You have ten arms or more, and you can hold up to ten objects normally. If you have more than ten arms, you can hold more by taking the unbalanced status. This allows you to ready or hold additional weapons or objects at once. You may use moments to grab objects or reload without becoming distracted, and you gain barrage as a supported maneuver for your fighting style. When using multiweapon fighting, you can reroll any result of 2 to X on an applicable fight roll, where X is the number of weapons you have in hand (maximum if 6). However, any miss leaves you unbalanced. You may choose to strike normally (without this benefit to multiweapon fighting), losing the benefit and the penalty."
requirements = Array[String](["Movement: Myriapodal"])
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
