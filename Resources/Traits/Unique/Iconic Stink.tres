name = "Iconic Stink"
source = "Mutants in the Now, pg. 32"
type = 3
cost = 2
description = "When a foe moves into melee with you, you may expend focus to bully them immediately as a reaction. If you have Stink Spray and they’re currently affected by it, gain +A on this roll."
