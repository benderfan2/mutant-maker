[resource]
script = ExtResource("2_bxyxj")
name = "Gilatoxin"
source = "Mutants in the Now, pg. 25"
type = 3
cost = 10
description = "Your bite carries a 1d6 toxin that inflicts agony on any foe you bite successfully for as long as they’re envenomed. Your teeth gain the injector trait, and this functions as if you had the venom trait."
requirements = Array[String](["Teeth"])
