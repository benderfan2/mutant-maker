name = "Poison Spurs"
source = "Mutants in the Now, pg. 30"
type = 3
cost = 15
description = "Your spurs carry a 1d8 toxin that inflicts agony and unbalanced for as long as they’re envenomed. Your spurs gain the injector trait, and this functions as if you had the venom trait."
