[resource]
script = ExtResource("1_oc8pc")
name = "Babyguard"
source = "Mutants in the Now, pg. 28"
type = 3
cost = 5
description = "During a fight, you may declare you’re protecting an ally in melee with you as a moment. While doing so, all foes are +D to perform maneuvers against them unless you have a status. You may spend another moment to switch this protection to another ally in melee."
