[resource]
script = ExtResource("1_s3gqy")
name = "Mound-Buster"
source = "Mutants in the Now, pg. 29"
type = 3
cost = 2
description = "You gain +A on any roll to personally break a structure, and can break down non-fortified doors, small trees, signs, and similar structures no taller than the average height associated with your (Size Rating + 1) without a roll."
requirements = Array[String](["Claws"])
