name = "Flatout"
source = "Mutants in the Now, pg. 31"
type = 3
cost = 8
description = "When running on a flat area (like dry riverbeds or roads), increase your MOVE by 20%. After you take a move action, foes are +D on maneuvers against you until the start of your next turn."
