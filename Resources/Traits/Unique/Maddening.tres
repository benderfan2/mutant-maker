[resource]
script = ExtResource("1_tvb4s")
name = "Maddening"
source = "Mutants in the Now, pg. 24"
type = 3
cost = 2
description = "When you gain a critical hit on a maneuver against a foe while in melee, they lose 1 WILL. If they have 0 WILL when the crit occurs, they gain the disoriented status."
