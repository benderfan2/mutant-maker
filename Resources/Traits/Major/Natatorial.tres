name = "Natatorial"
source = "Mutants in the Now, pg. 43"
cost = 5
description = "Your species is at home in the water. You gain the Swimming skill as a specialty skill and may swim at your full MOVE. If you’re already trained in the Swimming skill, make it a specialty skill and advance the skill three times."
