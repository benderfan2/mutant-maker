[resource]
script = ExtResource("1_3iphi")
name = "Unnerving Vocalization"
cost = 3
description = "Your species has an eerie call, howl, trumpet, or snicker that can alarm other species. When you bully a foe, they become disoriented in addition to startled. You add the bully maneuver to your fighting style. This does not affect targets that have the same classification type as you. If you have multiple sub-traits that enhance this, only one may be used per bully maneuver."
subtraits = Array[ExtResource("1_3iphi")]([ExtResource("2_14l58"), ExtResource("3_lstdd"), ExtResource("4_wfi5i"), ExtResource("5_q0eio")])
