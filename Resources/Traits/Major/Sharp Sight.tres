[resource]
script = ExtResource("1_7undd")
name = "Sharp Sight"
cost = 5
description = "You suffer no +D for dramatic rolls done to notice details or creatures while sprinting, and you do not suffer +D to use a maneuver against a sprinting target. In addition, you gain +A on maneuvers if you have moved this turn."
