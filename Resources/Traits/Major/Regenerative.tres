[resource]
script = ExtResource("1_m2tyl")
name = "Regenerative"
cost = 5
description = "You heal 100% faster. By spending 1 WILL, you may heal Endurance dice in damage worth of SHT as a moment in a fight scene. If your SHT is 0, you may not perform this effect. You may also spend 1 WILL to make a severing injury non-severing."
