[resource]
script = ExtResource("1_4f3ad")
name = "Suction"
source = "Mutants in the Now, pg. 44"
cost = 5
description = "You can pull water through your body to draw in prey. When underwater, you may take an action to pull a foe or ally into melee with you. This occurs automatically, but they may attempt a saving throw against it. If they succeed, they do not move, but if they fail, they become inactive and enter melee with you."
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
