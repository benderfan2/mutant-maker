name = "Active"
source = "Mutants in the Next, pg. 93"
type = 4
cost = 3
description = "As above, but you don’t need to lower your metabolism at all. However, you still can’t recover WILL without doing so. When you do so, you need only rest half the usual time (roughly 4 hours) to recover WILL. You only regain WILL on a 6 or higher."
