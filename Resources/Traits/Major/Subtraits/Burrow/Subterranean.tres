script = ExtResource("1_yxixg")
name = "Subterranean"
cost = 5
description = "Your MOVE reduction while digging becomes 1⁄4, and you gain +A on the next maneuver you perform the same turn you surface. If you have the Tunnel trait, treat your size rating as 2 higher for purposes of calculating the time it takes to build chambers and tunnels."
