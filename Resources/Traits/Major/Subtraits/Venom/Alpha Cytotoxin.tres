name = "Alpha Cytotoxin"
source = "Mutants in the Now, pg. 45"
type = 4
cost = 10
description = "This is a toxin rated 1d10 that inflicts damage to cellular structures throughout the body. While your foe is envenomed, they are unbalanced. If they succeed at a roll while envenomed, they suffer agony as well."
