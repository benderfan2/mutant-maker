name = "Bark"
source = "Mutants in the Now, pg. 45"
type = 4
cost = 2
description = "If you successfully bully a foe, they cannot reenter melee with you while they have any disoriented status you’ve inflicted. You cannot have this sub-trait if you have the Bellow sub-trait."
