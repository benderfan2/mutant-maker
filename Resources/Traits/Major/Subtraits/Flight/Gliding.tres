[resource]
script = ExtResource("2_thqga")
name = "Gliding"
cost = -5
is_universal = true
description = "You cannot gain lift on your own and must rely on natural lift. Flight requires you to jump from a substantial height; you cannot launch from the ground. To see if natural lift is available, roll 1d8; a 3 or less means you may gain altitude, but a 4 or higher means you must gradually descend for the rest of the flight. In good weather, roll 1d6 instead. Cannot be combined with Burst, Hover, or Migratory."
requirements = [SubResource("Resource_ojf57")]
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
