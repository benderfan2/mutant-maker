script = ExtResource("1_xqsia")
name = "Gamma Bufotoxin"
cost = 5
description = "This is a toxin rated 1d8 that inhibits the circulatory system and inflicts hallucinogenic effects. While your foe is envenomed, they are disoriented. If you’re grabbed, the toxin is only 1d6."
