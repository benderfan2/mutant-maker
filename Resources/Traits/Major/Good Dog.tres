[resource]
script = ExtResource("1_uk7mi")
name = "Good Dog"
cost = 5
description = "Most humans will do their best to avoid harming you if you have not injured or threatened them, and they gain +D to attack you while you have not targeted them or their allies with a maneuver. Gain +A on any roll to try and deescalate a situation."
