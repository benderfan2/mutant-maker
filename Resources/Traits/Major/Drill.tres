[resource]
script = ExtResource("1_2qgjp")
name = "Drill"
source = "Mutants in the Next, pg. 91"
cost = 5
description = "You can drill or hammer into surfaces with a natural weapon with shattering force. This can break any most organically-derived substances, like wood, drywall, and mud, but not hard minerals like concrete or brick. This takes two actions in a fight, or a moment if you spend 1 WILL. The GM may rule it takes longer if it’s thicker than a door or mid-sized tree. Knocking over objects like trees may create a hazard (Now, pg. 81) targeting a melee or non-melee combatant randomly, but you can spend 1 WILL to target a specific melee or a single foe not in a melee."
requirements = [SubResource("Resource_7bu3k")]
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
