script = ExtResource("1_2pkwj")
name = "Hooves"
type = 1
cost = 1
description = "You have hooved feet. When used as a natural weapon for kicks, treat your size rating as if it were 1 larger for purposes of unarmed damage. In addition, you gain Resistance 4 against hazards inflicted by you stepping on them (like hot coals, caltrops, etc.)."
