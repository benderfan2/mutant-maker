script = ExtResource("1_irhab")
name = "Apex Predator"
type = 1
cost = 1
description = "When in your species’ natural environment, no natural, non-mutated animal will initiate a fight with you unless you attack or threaten them first. If something unnatural drives them to do so, they are +D on maneuvers against you unless you perform a maneuver against them or actively harm them."
