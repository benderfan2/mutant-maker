script = ExtResource("1_0jrl0")
name = "Heel"
type = 1
cost = 1
description = "When you are surprised by a foe that moves into melee with you, have no +D to perform a strike with your spurs in the first turn of a fight scene, and their damage is increased to 2d8. When you perform such a strike, lose the unbalanced status if you have it before rolling."
