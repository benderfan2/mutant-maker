[ext_resource type="Script" uid="uid://bvg3dreo5cyh" path="res://Scripts/trait.gd" id="1_cojmh"]

[resource]
script = ExtResource("1_cojmh")
name = "Balancing Tail"
source = "Mutants in the Next, pg. 96"
type = 1
cost = 1
description = "You have a long tail used to help balance your body when running bipedally. When making a dramatic roll to maintain balance on rough terrain while running, add +A, and reduce the difficulty of retreat and traverse actions by 1."
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
