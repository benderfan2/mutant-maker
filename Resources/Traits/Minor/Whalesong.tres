[resource]
script = ExtResource("1_oki1i")
name = "Whalesong"
type = 1
cost = 1
description = "You may communicate with cetaceans of size 15 or greater while immersed in water, up to a distance of Endurance miles. The concepts you communicate are limited to a single word; “danger”, “come”, “’sup”, etc. This allows you to conduct social interaction with cetaceans of that size."
