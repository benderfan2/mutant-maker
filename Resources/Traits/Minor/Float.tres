name = "Float"
type = 1
cost = 1
description = "You cannot sink in water unless you choose to dive, and you do not need to make rolls to travel on the surface outside of unusually rough conditions. Moving on water this way reduces your MOVE to 1⁄2 unless you have Natatorial."
