[resource]
script = ExtResource("1_s30sx")
name = "Ultraviolet Sight"
type = 1
cost = 1
description = "In addition to the human spectrum of light, you can see some amount of the ultraviolet spectrum. This is most often used to notice food (such as lichens or flowers that are more recognizable under UV), particular markings left by some species, special mating plumages, or artificially created UV-florescent materials."
