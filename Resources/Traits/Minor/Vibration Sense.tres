[resource]
script = ExtResource("1_4lri1")
name = "Vibration Sense"
type = 1
cost = 1
description = "You can sense other creatures by impacts they make on the earth, preventing you from gaining +D on any dramatic roll to sense creatures. You cannot sense creatures with a size rating of 4 less than you in this fashion. This only provides vague information (rough size, footfall pattern). This can be used while digging to sense creatures on the surface."
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
