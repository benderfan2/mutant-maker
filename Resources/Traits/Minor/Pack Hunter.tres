[resource]
script = ExtResource("1_vnau3")
name = "Pack Hunter"
type = 1
cost = 1
description = "When hunting cooperatively, you add +1 to your +AFF when determining the benefits of teamwork on dramatic rolls related to the hunt. Add an additional +1 for each ally participating in teamwork that also has the Pack Hunter trait."
