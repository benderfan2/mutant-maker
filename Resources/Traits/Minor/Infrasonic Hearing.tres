[resource]
script = ExtResource("1_drv61")
name = "Infrasonic Hearing"
type = 1
cost = 1
description = "In addition to the human range of hearing, you can hear sounds in the infrasonic range. Infrasound is typically produced by weather, tectonic events, some large species, and some engines and machines, and travels farther and penetrates objects more easily than normal sound."
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
