[resource]
script = ExtResource("1_rvg3f")
name = "Ultrasonic Hearing"
type = 1
cost = 1
description = "In addition to the normal range of hearing, you can hear sounds in the ultrasonic range. Some animals use these frequencies in echolocation, and some electrical systems create this sound, like light bulbs."
