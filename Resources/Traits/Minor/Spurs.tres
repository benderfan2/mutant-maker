[resource]
script = ExtResource("1_qa3vo")
name = "Spurs"
type = 1
cost = 1
description = "This represents a variety of spiky growths that inflict 1d8 weapon damage at +D, with the supported maneuver: counter. This +D is negated if your spurs are performing a maneuver supported by this trait or you have the grabbed status and are targeting your grabbing foe. They have the edged type."
