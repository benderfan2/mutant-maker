[resource]
script = ExtResource("1_5e535")
name = "Distasteful"
source = "Mutants in the Next, pg. 96"
type = 1
cost = 1
description = "You taste bitter and bad. Any foe that inflicts damage to you with mouthparts during a maneuver or attempts to inflict swallowed against you for the first time in a scene becomes stunned afterwards. They can perform a saving throw against being stunned, but a failed save inflicts the tired and unbalanced statuses as well, and reinforces stunned."
metadata/_custom_type_script = "uid://bvg3dreo5cyh"
