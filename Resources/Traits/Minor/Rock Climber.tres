name = "Rock Climber"
type = 1
cost = 1
description = "You gain no +D or MOVE loss for moving across mountainous or rocky terrain, and you may ascend with MOVE reduced to 1⁄2 on a reasonable grade (that is, not flatly vertical, and with footholds) without needing a dramatic roll."
