[resource]
script = ExtResource("1_uo4yx")
name = "Bed Treader"
type = 1
cost = 1
description = "Instead of swimming, you may move along the bed of a body of water, moving at 3⁄4 of your land MOVE. This doesn’t require a roll outside of powerful currents, but it is limited by your ability to breathe."
