[resource]
script = ExtResource("1_tid1j")
name = "Standing Posture"
type = 1
cost = 1
description = "You may take an action to stand on your hind legs to reach higher or to use your forelimbs as weapons, but you cannot take a move action while doing so. When attacking with your forelimbs while using this trait, you increase your lowest damage die but gain the distracted status."
requirements = ["Quadrupedal"]
