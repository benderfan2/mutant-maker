name = "Aposematic"
source = "Mutants in the Next, pg. 96"
type = 1
cost = 1
description = "You have bright colors that warn predators of your toxicity, or act as a daring bluff. In the wild, no animal will attack you unless they have adapted specifically to eat your species (usually involving the Toxin Digestion trait)."
